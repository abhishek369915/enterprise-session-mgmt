# Environment: development | qa | staging | production
VITE_APP_ENV=development

# Auth0 (replace with real values)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your_client_id
VITE_AUTH0_AUDIENCE=https://your-api.example.com

# SAML (replace with real values)
VITE_SAML_ENTRY_POINT=https://idp.example.com/sso
VITE_SAML_ISSUER=enterprise-session-mgmt
